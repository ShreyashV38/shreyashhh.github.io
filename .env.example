# ── Backend ─────────────────────────────────────────────────────
APP_ID=                   # Application ID
APP_SECRET=               # Application secret (used for JWT signing)

# ── Database ───────────────────────────────────────────────────
# Connection string for your database (e.g. MySQL, PostgreSQL, etc)
DATABASE_URL="mysql://user:password@host:3306/db"

# ── Email Notification ─────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
CONTACT_EMAIL=
